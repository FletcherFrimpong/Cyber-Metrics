# SignalFoundry Environment Configuration

# =============================================================================
# AUTHENTICATION
# =============================================================================
# Secret key for signing JWT session tokens. MUST be set in production.
# Generate with: openssl rand -base64 32
# AUTH_SECRET=your-secure-random-secret-here

# Default admin account is created automatically on first run:
#   Username: admin
#   Password: SignalFoundry2024!
# Change this immediately after first login via Settings > User Management.

# =============================================================================
# EMAIL / SMTP (Optional — enables email invitations)
# =============================================================================
# If not configured, user invitations still work but credentials are shown
# on-screen only (no email sent).
#
# Works with any SMTP provider: Gmail, Outlook/Exchange, Amazon SES, SendGrid, etc.
# For Gmail: use smtp.gmail.com port 587, generate an App Password in your Google account.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="SignalFoundry <noreply@yourcompany.com>"

# Optional: Override the login URL in invite emails (useful behind reverse proxy)
# APP_URL=https://signalfoundry.yourcompany.com

# =============================================================================
# MICROSOFT SENTINEL INTEGRATION (Primary — connects your SIEM)
# =============================================================================
# Create an App Registration in Azure AD with these API permissions:
#   - Microsoft Graph → SecurityIncident.Read.All
#   - Microsoft Graph → SecurityAlert.Read.All
#
# Then create a client secret and fill in the values below.

# Required: Azure AD service principal credentials
# Permissions needed:
#   SecurityIncident.Read.All  — pull resolved incidents
#   SecurityAlert.Read.All     — pull alert details
#   User.Read.All              — resolve user departments from Azure AD
#   Device.Read.All            — resolve device owners for department mapping
SENTINEL_TENANT_ID=your-azure-ad-tenant-id
SENTINEL_CLIENT_ID=your-app-registration-client-id
SENTINEL_CLIENT_SECRET=your-app-registration-client-secret

# Optional: For workspace-scoped queries via ARM SDK
SENTINEL_SUBSCRIPTION_ID=your-subscription-id
SENTINEL_RESOURCE_GROUP=your-resource-group-name
SENTINEL_WORKSPACE_NAME=your-sentinel-workspace-name
SENTINEL_WORKSPACE_ID=your-log-analytics-workspace-id

# Optional: Polling interval in milliseconds (default: 900000 = 15 minutes)
# SENTINEL_POLLING_INTERVAL=900000

# Optional: HMAC secret for webhook signature verification
# Used by Sentinel automation rules / Logic Apps pushing to POST /api/sentinel/webhook
# SENTINEL_WEBHOOK_SECRET=your-shared-secret

# =============================================================================
# LEGACY: Direct Azure Sentinel/Subscription Config
# =============================================================================

# Your Azure Subscription ID (found in Azure Portal > Subscriptions)
AZURE_SUBSCRIPTION_ID=your-subscription-id-here

# The Resource Group containing your Sentinel workspace
AZURE_RESOURCE_GROUP=your-resource-group-name

# Your Sentinel workspace name
AZURE_WORKSPACE_NAME=your-workspace-name

# Optional: Azure Tenant ID (if using service principal authentication)
# AZURE_TENANT_ID=your-tenant-id

# Optional: Azure Client ID (if using service principal authentication)
# AZURE_CLIENT_ID=your-client-id

# Optional: Azure Client Secret (if using service principal authentication)
# AZURE_CLIENT_SECRET=your-client-secret

# Industry Configuration for Cost Calculations
# Set your industry type to adjust cost calculations based on industry-specific multipliers
# Options: Healthcare, Financial Services, Technology, Energy, Manufacturing, Retail, Education, Government, Hospitality, Professional Services
INDUSTRY_TYPE=Technology

# Note: The application currently uses sample data and does not require
# any external connections. Azure configuration is for future real data integration. 

# =============================================================================
# SECURE CREDENTIAL MANAGEMENT - PRODUCTION SETUP
# =============================================================================

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/signal_foundry"

# =============================================================================
# OPTION 1: ENVIRONMENT VARIABLES (Development Only)
# =============================================================================
# WARNING: Do NOT use this in production! Use secret management systems below.

# EDR API Configuration
NEXT_PUBLIC_EDR_PLATFORM="crowdstrike" # Options: crowdstrike, microsoft-defender, sentinelone, carbon-black
NEXT_PUBLIC_EDR_BASE_URL="https://api.crowdstrike.com"
NEXT_PUBLIC_EDR_API_KEY="" # API key for platforms that use direct API key authentication

# CrowdStrike specific configuration
NEXT_PUBLIC_CROWDSTRIKE_CLIENT_ID=""
NEXT_PUBLIC_CROWDSTRIKE_CLIENT_SECRET=""

# Microsoft Defender specific configuration
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=""
NEXT_PUBLIC_MICROSOFT_CLIENT_SECRET=""
NEXT_PUBLIC_MICROSOFT_TENANT_ID=""

# =============================================================================
# OPTION 2: HASHICORP VAULT (Production Recommended)
# =============================================================================
# VAULT_URL="https://vault.yourcompany.com"
# VAULT_TOKEN="your-vault-token"
# VAULT_PATH="edr-config"

# =============================================================================
# OPTION 3: AWS SECRETS MANAGER (Production)
# =============================================================================
# AWS_SECRETS_SECRET_NAME="signal-foundry/edr-config"
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"

# =============================================================================
# OPTION 4: AZURE KEY VAULT (Production)
# =============================================================================
# AZURE_KEYVAULT_NAME="your-keyvault-name"
# AZURE_KEYVAULT_SECRET_NAME="edr-config"
# AZURE_TENANT_ID="your-tenant-id"
# AZURE_CLIENT_ID="your-client-id"
# AZURE_CLIENT_SECRET="your-client-secret"

# =============================================================================
# OPTION 5: GOOGLE CLOUD SECRET MANAGER (Production)
# =============================================================================
# GCP_PROJECT_ID="your-project-id"
# GCP_SECRET_ID="edr-config"
# GOOGLE_APPLICATION_CREDENTIALS="path/to/service-account.json"

# =============================================================================
# ENCRYPTION (Optional)
# =============================================================================
# ENCRYPTION_KEY="your-encryption-key" # For additional data encryption 